{
  "name": "@prufs/sync",
  "version": "0.1.0",
  "description": "Bidirectional sync engine between @prufs/store (local SQLite) and @prufs/cloud (api.prufs.ai + R2)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/*.test.js",
    "prepublishOnly": "npm run build",
    "prepack": "rm -f dist/*.test.* dist/*.test.*.map dist/test-helpers.*"
  },
  "keywords": [
    "prufs",
    "sync",
    "vcs",
    "agentic",
    "decision-trail",
    "causal-commit"
  ],
  "author": "Wade Lovell <wade@cognitionhive.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prufs-ai/prufs.git",
    "directory": "packages/sync"
  },
  "homepage": "https://prufs.ai",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  }
}
