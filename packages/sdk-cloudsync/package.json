{
  "name": "@prufs/sdk-cloudsync",
  "version": "0.2.1",
  "description": "CloudSync module for @prufs/sdk, a one-import wrapper around @prufs/sync",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/*.test.js",
    "clean": "rm -rf dist",
    "prepack": "rm -f dist/*.test.* dist/*.test.*.map"
  },
  "dependencies": {
    "@prufs/sync": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  },
  "bundledDependencies": [
    "@prufs/sync"
  ]
}
